{
  "$schema": "https://raw.githubusercontent.com/googleapis/release-please/main/schemas/config.json",
  "release-type": "python",
  "packages": {
    ".": {
      "package-name": "csp0924_lib",
      "component": "csp_lib",
      "include-component-in-tag": false,
      "include-v-in-tag": true,
      "changelog-path": "CHANGELOG.md",
      "bump-minor-pre-major": true,
      "bump-patch-for-minor-pre-major": false,
      "draft": false,
      "prerelease": false,
      "extra-files": [
        {
          "type": "python",
          "path": "csp_lib/__init__.py"
        }
      ],
      "changelog-sections": [
        { "type": "feat",     "section": "Added",      "hidden": false },
        { "type": "fix",      "section": "Fixed",      "hidden": false },
        { "type": "perf",     "section": "Performance","hidden": false },
        { "type": "refactor", "section": "Changed",    "hidden": false },
        { "type": "revert",   "section": "Reverted",   "hidden": false },
        { "type": "docs",     "section": "Documentation","hidden": true },
        { "type": "style",    "section": "Style",      "hidden": true },
        { "type": "test",     "section": "Tests",      "hidden": true },
        { "type": "ci",       "section": "CI",         "hidden": true },
        { "type": "chore",    "section": "Chore",      "hidden": true },
        { "type": "build",    "section": "Build",      "hidden": true }
      ]
    }
  },
  "release-search-depth": 400,
  "commit-search-depth": 500,
  "pull-request-title-pattern": "chore${scope}: release ${version}",
  "pull-request-header": ":robot: 本 Release PR 由 release-please 自動維護。合併後會自動：建立 git tag、觸發 PyPI 發佈、產生 GitHub Release。",
  "separate-pull-requests": false
}
